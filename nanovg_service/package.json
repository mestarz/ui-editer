    "express": "^4.21.2",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.10"
  }
}
