{
  "name": "nanovg-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n SRV,WEB -c blue,green \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "node server/index.js",
